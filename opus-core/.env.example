# OPUS — environment template.
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#

# Required. Your Anthropic API key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Override default models per tier.
# OPUS_WORKER_MODEL=claude-opus-4-7
# OPUS_SCOUT_MODEL=claude-sonnet-4-6
# OPUS_JUDGE_MODEL=claude-opus-4-7
# OPUS_VERIFIER_MODEL=claude-opus-4-7

# Optional. Hard ceiling on total USD per query. Default: unbounded for v0.
# OPUS_BUDGET_USD=2.00

# Optional. Hard ceiling on agent rounds per query. Default: 3.
# OPUS_MAX_ROUNDS=3

# Optional. Path for provenance JSONL output. Default: ./provenance/
# OPUS_PROVENANCE_DIR=./provenance
